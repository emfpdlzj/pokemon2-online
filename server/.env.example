# Server-only overrides. Copy to server/.env when needed.

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=pokemon2;Username=postgres;Password=postgres
# POKEMON2_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokemon2

# Player identity signing secret. Required outside Development.
POKEMON2_PLAYER_IDENTITY_SECRET=

# Server-side LLM configuration. The client now calls the backend proxy, so
# keep credentials only on the server.
POKEMON2_LLM_API_KEY=
POKEMON2_LLM_API_URL=
POKEMON2_LLM_MODEL=
POKEMON2_LLM_REPLY_MODEL=
POKEMON2_LLM_CHOICES_MODEL=
POKEMON2_LLM_REPLY_MAX_OUTPUT_TOKENS=120
POKEMON2_LLM_CHOICES_MAX_OUTPUT_TOKENS=180
POKEMON2_LLM_REPLY_PROMPT_COST_PER_1K_USD=0
POKEMON2_LLM_REPLY_COMPLETION_COST_PER_1K_USD=0
POKEMON2_LLM_CHOICES_PROMPT_COST_PER_1K_USD=0
POKEMON2_LLM_CHOICES_COMPLETION_COST_PER_1K_USD=0
POKEMON2_LLM_RATE_LIMIT_PER_MINUTE=30

# Datadog DogStatsD exporter. The server publishes metrics only when enabled.
# Run the Datadog Agent with: docker compose --profile observability up -d datadog
POKEMON2_DOGSTATSD_ENABLED=false
POKEMON2_DOGSTATSD_HOST=127.0.0.1
POKEMON2_DOGSTATSD_PORT=8125
POKEMON2_METRICS_INTERVAL_SECONDS=10
DD_SERVICE=pokemon2-online-server
DD_ENV=local
# DD_VERSION=dev

# Admin metrics protection. Use either a token, an IP allowlist, or both.
POKEMON2_ADMIN_TOKEN=
POKEMON2_ADMIN_ALLOWLIST=127.0.0.1
AdminApi__AllowLoopbackInDevelopment=true
